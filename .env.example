#
# =============================================================================
# 🔐 ENVIRONMENT VARIABLES TEMPLATE - .env.example
# =============================================================================
#
# PURPOSE:
# --------
# This is a TEMPLATE file showing what environment variables you need to set.
# Copy this file to ".env" and fill in your actual values.
#
# HOW TO USE:
# -----------
# 1. Copy this file: copy .env.example .env
# 2. Edit .env and add your real values
# 3. NEVER commit .env to git (it's in .gitignore for safety)
#
# =============================================================================

# Your Gmail address (sender)
MY_EMAIL=your_email@gmail.com

# Your Gmail App Password (16 characters, no spaces)
# Get it from: https://myaccount.google.com/apppasswords
MY_PASSWORD=xxxx xxxx xxxx xxxx

# 📧 Recipients - separate multiple emails with commas (NO spaces after commas)
# Examples:
#   Single:   TO_EMAIL=you@gmail.com
#   Multiple: TO_EMAIL=you@gmail.com,friend@gmail.com,family@gmail.com
TO_EMAIL=your_email@gmail.com

# =============================================================================
# 📊 DAILY SUMMARY SETTINGS (Optional)
# =============================================================================

# Set to "true" to receive a daily "no new events" email
# This confirms the tracker is working even when nothing new is found
DAILY_SUMMARY_ENABLED=true

# Hour to send daily summary (0-23, in UTC timezone)
# Example: 9 = 9:00 AM UTC = 1:00 PM Dubai time (UTC+4)
DAILY_SUMMARY_HOUR=9

# =============================================================================
# 💓 HEARTBEAT SETTINGS (Confirms bot is running 24/7)
# =============================================================================

# Set to "true" to receive heartbeat emails confirming bot is alive
# This sends a status email every X hours to confirm the bot is running
HEARTBEAT_ENABLED=true

# How often to send heartbeat emails (in hours)
# Example: 3 = every 3 hours you'll get a "bot is running" email
HEARTBEAT_HOURS=3

# Email address to receive heartbeat notifications
# This can be different from TO_EMAIL (for admin monitoring)
# Leave empty if you're using Telegram for admin alerts
HEARTBEAT_EMAIL=admin@gmail.com

# =============================================================================
# 📱 TELEGRAM BOT SETTINGS (Recommended - Instant & Free)
# =============================================================================

# Get your bot token from @BotFather on Telegram
# See docs/telegram_chatid.md for full setup guide
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGhIjKlMnOpQrStUvWxYz

# Comma-separated chat IDs who receive NEW EVENT alerts
# Get your chat ID: Search @userinfobot on Telegram and send any message
# Example: 1234567890,9876543210
TELEGRAM_CHAT_IDS=1234567890,9876543210

# Single admin chat ID for heartbeat, errors, and status messages
# Usually your personal chat ID
TELEGRAM_ADMIN_CHAT_ID=1234567890

# =============================================================================
# 🔧 ADVANCED SETTINGS (Usually don't need to change)
# =============================================================================

# Admin password for dashboard access (REQUIRED for security)
ADMIN_PASSWORD=your_secure_password_here

# =============================================================================
# 🗄️ TURSO DATABASE (Required for cloud persistence)
# =============================================================================

# Create a free database at https://turso.tech
# Install CLI: curl -sSfL https://get.tur.so/install.sh | bash
# Create DB:   turso db create your-db-name
# Get URL:     turso db show your-db-name --url
# Get Token:   turso db tokens create your-db-name

TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here
